tests = [ True
# Booleans
, not False
, not (not (not False))
, not (not True)
, and True True
, or False True
, xor True False

# Functions
, eq (id 3) 3
, eq (constant 3 2) 3
, eq (apply Succ 2) 3
, eq (compose Succ Succ 1) 3

# Maybe
, eq (fromMaybe 2 (Just 3)) 3
, eq (fromMaybe 2 Nothing) 2

# Naturals
, eq (times two three) (plus two (times two two))
, lt one two
, lte two two
, gt three two
, gte three three
, eq 3 three
, eq (minus 7 5) 2
, eq (pred 3) 2
, is_zero (minus 3 7)
, eq (Z (fac: n: lte n 1 (u: 1) (u: times n (fac (minus n 1))) id) 5) 120

# Lists
, head (tail (tail [False, False, True]))
, eq (head (tail [1, 2, 3])) 2
];

or (all tests) (findIndex not tests)
